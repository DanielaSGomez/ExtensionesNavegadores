{
  "manifest_version": 3,
  "name": "Notas Rápidas",
  "version": "1.0",
  "description": "Extensión para tomar notas rápidas en el navegador",
  "author": "DanielaSGomez",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    },
  "default_popup_width": 400,
  "default_popup_height": 500
  }
}
